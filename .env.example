# ================================
# Northern Harvest - Docker Environment
# Copy this to .env in the project root before running docker-compose
# ================================

# Backend URL as seen by the browser (baked into frontend at build time)
# Local Docker:      http://localhost:5001
# Production:        https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:5001

# Port mapping (optional — change if defaults conflict)
BACKEND_PORT=5001
FRONTEND_PORT=3000

# ngrok auth token (only needed if using the "tunnel" profile)
NGROK_AUTHTOKEN=
